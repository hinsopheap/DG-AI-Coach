# Firebase Admin (required)
FIREBASE_PROJECT_ID=cambodia-ai-group
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Anthropic (required for AI coaching)
ANTHROPIC_API_KEY=

# Telegram (required for bot)
TELEGRAM_BOT_TOKEN=
# Secret path token used in /api/telegram/webhook/<secret> — must match setWebhook
TELEGRAM_WEBHOOK_SECRET=

# Cron security (required for schedule endpoints)
CRON_SECRET=

# Admin dashboard login (simple shared-secret bootstrap; replace with Firebase Auth later)
ADMIN_EMAIL=sopheap.hin@gmail.com
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Public base URL (for setting Telegram webhook)
PUBLIC_BASE_URL=

# Email service (optional — welcome email + password-reset email fallback).
# Without RESEND_API_KEY, signup still works; only the welcome email is skipped
# and password reset falls back to Telegram-only (which is the secure default).
# Get a key at https://resend.com — free tier covers pilot scale.
RESEND_API_KEY=
# Default from-address — set to an address on your verified Resend domain to
# deliver to anyone. Without verification you can only deliver to the email
# tied to your Resend account.
EMAIL_FROM=

# Speech-to-text (optional — enables Telegram voice notes).
# Without a key, voice notes get a friendly "type instead" reply.
GROQ_API_KEY=
OPENAI_API_KEY=
